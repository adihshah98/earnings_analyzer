OPENAI_API_KEY=sk-your-openai-key
# Direct Postgres connection (Supabase: Project Settings > Database, or Render Postgres)
# Format: postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/postgres
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
LOG_LEVEL=INFO
# Admin API key — required to call ingest and eval routes.
# Leave empty in local dev (disables protection). Set a strong secret in production.
ADMIN_API_KEY=secret
# Allowed CORS origins — comma-separated list of frontend URLs.
CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
# For run_evals.py and run_retrieval_evals.py — API base URL (default: deployment).
# Set to http://localhost:8000 for local API.
BASE_URL=https://your-backend.onrender.com
